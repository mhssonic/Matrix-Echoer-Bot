# =============================================================================
# Copy this file to .env and fill in your real values
# =============================================================================

# --- Matrix (pick ONE style) ---

# Single room (legacy):
MATRIX_HOMESERVER=https://matrix.org
MATRIX_USER_ID=@yourbot:matrix.org
MATRIX_ACCESS_TOKEN=your_matrix_access_token_here
MATRIX_ROOM_ID=!yourroomid:matrix.org

# Multiple rooms / servers / accounts (comma-separated, same length for each list):
# MATRIX_HOMESERVERS=https://a.example.org,https://b.example.org
# MATRIX_USER_IDS=@bot:a.example.org,@bot:b.example.org
# MATRIX_ACCESS_TOKENS=token_for_a,token_for_b
# MATRIX_ROOM_IDS=!roomA:a.example.org,!roomB:b.example.org

TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_BOT_CHANNEL_CHAT_ID=-100xxxxxxxxxx
TELEGRAM_CLIENT_CHANNEL_CHAT_IDS=-100xxxxxxxxxx,-100yyyyyyyyyy

PROXY_URL=socks5://127.0.0.1:10808

MATRIX_CODE_READER_ROOM_ID=!yourroomid:matrix.org

TELEGRAM_API_ID=1234567
TELEGRAM_API_HASH=your_api_hash
TELEGRAM_PHONE_NUMBER=+98xxxxxxxxxx
TELEGRAM_PASSWORD=your_password

# If true/1/yes/on, videos won't be forwarded.
DISABLE_VIDEOS=false

# Optional: path to ffmpeg (default: ffmpeg on PATH). Used to shrink videos > 5MB before Matrix upload.
# FFMPEG_PATH=C:\path\to\ffmpeg.exe
